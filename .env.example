# Runtime DB connection for the app and Prisma client.
# For Supabase, use the TRANSACTION pooler / pooled runtime URL here.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true&connection_limit=1"

# Migration connection for Prisma migrate.
# For Supabase, use the SESSION pooler / direct connection string here.
# Falls back to DATABASE_URL if omitted, but keeping it explicit is recommended.
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"

# Auth.js secret for signing sessions/JWTs.
AUTH_SECRET="replace-with-a-long-random-secret"

# Single-user seed account used by prisma/seed.ts.
SEED_USER_EMAIL="you@example.com"
SEED_USER_PASSWORD="replace-with-a-strong-password"
SEED_USER_NAME="Your Name"

# Optional: override Pino log level.
# LOG_LEVEL="debug"
