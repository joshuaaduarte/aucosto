// Finance tool.
//
// Money is stored as integer minor units (cents for USD). The display layer
// divides by 100. Never use Float for money. Sign convention: negative amount
// = debit/outflow, positive = credit/inflow.

model FinanceAccount {
  id                   String   @id @default(cuid())
  userId               String
  name                 String
  kind                 String
  currency             String   @default("USD")
  currentBalanceCents  Int
  balanceUpdatedAt     DateTime
  statementBalanceCents Int?
  dueDate              DateTime?
  creditLimitCents     Int?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, kind])
  @@unique([userId, name])
}

model FinanceTransaction {
  id          String   @id @default(cuid())
  userId      String
  date        DateTime
  amount      Int
  currency    String   @default("USD")
  description String
  account     String?
  category    String?
  raw         String?
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date])
}
