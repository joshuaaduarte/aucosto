// Do list.
// Tasks are intentionally lightweight but time-aware, so they can power
// suggestions in both the calendar and timer without becoming project
// management software.

model DoItem {
  id               String      @id @default(cuid())
  userId           String
  title            String
  lane             String      @default("next")
  status           String      @default("open")
  estimatedMinutes Int?
  actualMinutes    Int?
  notes            String?
  completedAt      DateTime?
  lastWorkedAt     DateTime?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  user             User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  timeEntries      TimeEntry[]

  @@index([userId, status, lane, createdAt])
  @@index([userId, completedAt])
}
