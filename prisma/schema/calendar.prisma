// Personal planning calendar.
// V1 is intentionally narrow: native blocks + derived/actionable surfaces.
// External sync can map into the same table later via kind/source metadata.

model CalendarItem {
  id         String   @id @default(cuid())
  userId     String
  title      String
  kind       String   @default("block")
  status     String   @default("confirmed")
  startsAt   DateTime
  endsAt     DateTime
  allDay     Boolean  @default(false)
  // Optional link to a user-managed TimeCategory (tints the block; pre-selects
  // the timer category when the block is happening now). Like TimeCategory
  // itself, this column is created via raw SQL (`ensureCalendarCategoryColumn`
  // in src/lib/services/calendar.ts), NOT `prisma migrate` — the generated
  // client predates it, so the service reads/writes it through $queryRaw /
  // $executeRaw until the next `prisma generate`. Declared here so that
  // generate eventually picks up the type and the raw queries can be retired.
  categoryId String?
  sourceTool String?
  sourceRefId String?
  notes      String?
  location   String?
  externalId String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, startsAt])
  @@index([userId, status, startsAt])
  @@unique([userId, externalId])
}
