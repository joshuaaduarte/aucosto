// Personal planning calendar.
// V1 is intentionally narrow: native blocks + derived/actionable surfaces.
// External sync can map into the same table later via kind/source metadata.

model CalendarItem {
  id         String   @id @default(cuid())
  userId     String
  title      String
  kind       String   @default("block")
  status     String   @default("confirmed")
  startsAt   DateTime
  endsAt     DateTime
  allDay     Boolean  @default(false)
  sourceTool String?
  sourceRefId String?
  notes      String?
  location   String?
  externalId String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, startsAt])
  @@index([userId, status, startsAt])
  @@unique([userId, externalId])
}
