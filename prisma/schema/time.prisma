// Time tracking tool.

model TimeEntry {
  id        String    @id @default(cuid())
  userId    String
  doItemId  String?
  habitId   String?
  projectId String?
  label     String
  category  String?
  startedAt DateTime
  endedAt   DateTime?
  notes     String?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  doItem    DoItem?   @relation(fields: [doItemId], references: [id], onDelete: SetNull)
  habit     Habit?    @relation(fields: [habitId], references: [id], onDelete: SetNull)
  project   Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([userId, startedAt])
  @@index([doItemId, startedAt])
  @@index([habitId, startedAt])
  @@index([projectId, startedAt])
}

// User-manageable life categories for the time tracker.
//
// NOTE: like the projects board, this table is created via raw SQL
// (`ensureTimeCategoryTable()` in src/lib/services/time-categories.ts), NOT via
// `prisma migrate`. It lives here so a regular `prisma generate` picks up the
// types; until then the service reads/writes through raw SQL (reflect.ts
// pattern). The stored TimeEntry.category value stays the normalized name, so
// the pure `categoryColor`/`categoryLabel` helpers keep resolving presets.
model TimeCategory {
  id        String   @id @default(cuid())
  userId    String
  name      String
  color     String   @default("#6366f1")
  emoji     String?
  isHidden  Boolean  @default(false)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  @@index([userId, sortOrder])
}
