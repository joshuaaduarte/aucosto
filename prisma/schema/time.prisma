// Time tracking tool.

model TimeEntry {
  id        String    @id @default(cuid())
  userId    String
  doItemId  String?
  label     String
  category  String?
  startedAt DateTime
  endedAt   DateTime?
  notes     String?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  doItem    DoItem?   @relation(fields: [doItemId], references: [id], onDelete: SetNull)

  @@index([userId, startedAt])
  @@index([doItemId, startedAt])
}
